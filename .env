EXPO_PUBLIC_API_BASE=http://192.168.1.3:3001

# ── Preview / test mode ──────────────────────────────────────────────
# Render pages with dummy data instead of calling the API.
# Set to 1 to enable, then restart the bundler: expo start -c
EXPO_PUBLIC_PREVIEW=0
# Which Mirror state to preview: forming | teaser | full
EXPO_PUBLIC_PREVIEW_MIRROR=full
EXPO_PUBLIC_PREVIEW=1
