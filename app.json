{
  "expo": {
    "name": "Grittt",
    "slug": "grittt-app",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "grittt",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0F0F14"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.grittt.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Allow Grittt to access your photos to track your food.",
        "NSCameraUsageDescription": "Allow Grittt to use your camera to snap and track food.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "runtimeVersion": "1.0.1"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F0F14"
      },
      "package": "com.grittt.app",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.RECORD_AUDIO"
      ],
      "runtimeVersion": {
        "policy": "appVersion"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Grittt to access your photos to track your food.",
          "cameraPermission": "Allow Grittt to use your camera to snap and track food."
        }
      ],
      "expo-web-browser",
      "expo-font",
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4344d3a6-60dc-4ecd-909f-0fe591ed926b"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/4344d3a6-60dc-4ecd-909f-0fe591ed926b"
    }
  }
}
